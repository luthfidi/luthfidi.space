# Site
DOMAIN=https://luthfidi.space
NEXT_PUBLIC_AUTHOR_EMAIL=luthfihadi543@gmail.com

# GitHub (required for /dashboard contributions widget)
# https://github.com/settings/tokens — needs `read:user` scope
GITHUB_READ_USER_TOKEN_PERSONAL=

# Resend (contact form). If empty, the form silently logs to the server console.
# https://resend.com/api-keys
RESEND_API_KEY=
# Optional: a verified Resend "from" address. Defaults to onboarding@resend.dev.
RESEND_FROM_EMAIL=

# --- Optional dashboard widgets (leave empty to render an empty state) ---

# Wakatime — https://wakatime.com/api-key
WAKATIME_API_KEY=

# Monkeytype — https://monkeytype.com/account → ApeKeys
MONKEYTYPE_API_KEY=

# Umami Analytics — https://cloud.umami.is
UMAMI_API_KEY=
UMAMI_WEBSITE_ID_MYID=
